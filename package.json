    "@types/recharts": "^1.8.29",
    "@vinejs/vine": "^4.3.0",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.38.0",
    "joi": "^18.1.2",
    "jsencrypt": "^3.5.4",
    "lucide-react": "^1.7.0",
    "moment": "^2.30.1",
    "nanoid": "^5.1.7",
    "nope-validator": "^1.1.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "to-words": "^5.4.0",
    "zustand": "^5.0.12"
