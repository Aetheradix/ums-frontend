{
  "name": "university-ms-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md}": "prettier --write"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build-local": "tsc -b && vite build",
    "local-build": "npm run build-local",
    "build-testing": "tsc -b && vite build --mode testing",
    "build-prod": "tsc -b && vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "local": "NODE_ENV=local vite",
    "local-win": "SET NODE_ENV=local&&vite",
    "prepare": "husky",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
